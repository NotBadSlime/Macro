<UserControl x:Class="MacroStudio.Controls.PlaybackPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="2,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="PlaybackTitleText" Grid.ColumnSpan="3" Style="{StaticResource PanelTitle}" Text="播放" Margin="0,0,0,12" />
            <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
                <TextBlock x:Name="TriggerLabelText" Text="触发键" Style="{StaticResource FieldLabel}" />
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="CaptureTriggerButton" DockPanel.Dock="Right" Width="78" Content="捕获" Click="CaptureTrigger_Click" />
                    <TextBox x:Name="TriggerTextBox"
                             Height="30"
                             Margin="0,0,8,0"
                             IsReadOnly="True"
                             TextChanged="PlaybackSettings_TextChanged" />
                </DockPanel>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0">
                <TextBlock x:Name="ModeLabelText" Text="模式" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="PlaybackModeBox" Height="30" SelectionChanged="PlaybackModeBox_SelectionChanged">
                    <ComboBoxItem Tag="toggleLoop" Content="按下循环" />
                    <ComboBoxItem Tag="holdLoop" Content="按住循环" />
                    <ComboBoxItem Tag="fixedCount" Content="播放 N 次" IsSelected="True" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="2">
                <TextBlock x:Name="PlaybackCountLabelText" Text="次数" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="PlaybackCountTextBox" Height="30" Text="1" TextChanged="PlaybackSettings_TextChanged" />
            </StackPanel>

            <Grid Grid.Row="4" Grid.ColumnSpan="3" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="StartListeningButton"
                        Grid.Column="0"
                        MinWidth="0"
                        Content="开始监听"
                        Click="StartListening_Click" />
                <Button x:Name="StopListeningButton"
                        Grid.Column="2"
                        MinWidth="0"
                        Content="停止监听"
                        Click="StopListening_Click" />
                <Button x:Name="RunNowButton" Grid.Column="0" MinWidth="82" Content="立即运行" Visibility="Collapsed" Click="RunNow_Click" />
                <Button x:Name="StopPlaybackButton" Grid.Column="2" MinWidth="64" Content="停止" Visibility="Collapsed" Style="{StaticResource DangerButton}" Click="StopPlayback_Click" />
                <TextBlock x:Name="PlaybackStatusText"
                           Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Text="播放：空闲"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="PlaybackResultText"
                           Grid.Row="2"
                           Grid.ColumnSpan="3"
                           Text="上次结果：无"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryText}"
                           TextWrapping="Wrap" />
            </Grid>
    </Grid>
</UserControl>
