<UserControl x:Class="MacroStudio.Controls.McrxJsonPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelBorderStyle}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel x:Name="JsonApplyBar" Margin="0,0,0,10">
                <Button x:Name="ApplyJsonButton"
                        DockPanel.Dock="Right"
                        MinWidth="72"
                        Content="应用"
                        Click="ApplyJson_Click" />
            </DockPanel>

            <TextBox x:Name="MacroEditor"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     FontFamily="Consolas"
                     FontSize="13"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="180"
                     TextWrapping="NoWrap"
                     TextChanged="MacroEditor_TextChanged"
                     Padding="10" />
        </Grid>
    </Border>
</UserControl>
