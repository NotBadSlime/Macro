<Window x:Class="MacroStudio.Controls.ScreenRegionPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选取屏幕区域"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Cursor="Cross"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Grid>
        <!-- Semi-transparent overlay -->
        <Border x:Name="OverlayBackground"
                Background="#40000000" />

        <!-- Selection canvas -->
        <Canvas x:Name="SelectionCanvas">
            <!-- Selection rectangle -->
            <Border x:Name="SelectionRect"
                    Visibility="Collapsed"
                    BorderBrush="#FF4F46E5"
                    BorderThickness="2"
                    Background="#204F46E5">
                <Grid>
                    <TextBlock x:Name="SizeLabel"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold" />
                </Grid>
            </Border>

            <!-- Coordinate display -->
            <Border x:Name="CoordLabel"
                    Canvas.Left="10"
                    Canvas.Top="10"
                    Background="#CC1F2937"
                    CornerRadius="6"
                    Padding="12,6">
                <TextBlock x:Name="CoordText"
                           Foreground="White"
                           FontSize="13"
                           FontFamily="Consolas" />
            </Border>

            <!-- Color preview at cursor -->
            <Border x:Name="CursorPreview"
                    Width="80" Height="80"
                    Visibility="Collapsed"
                    CornerRadius="8"
                    BorderBrush="White"
                    BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border x:Name="PixelColorPreview" CornerRadius="6,6,0,0" />
                    <Border Grid.Row="1" Background="#CC000000" CornerRadius="0,0,6,6" Padding="4,2">
                        <TextBlock x:Name="PixelColorText"
                                   Foreground="White"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   FontFamily="Consolas" />
                    </Border>
                </Grid>
            </Border>
        </Canvas>

        <!-- Instructions -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,40"
                Background="#CC1F2937"
                CornerRadius="8"
                Padding="18,10">
            <TextBlock Foreground="White" FontSize="13">
                <Run Text="拖拽选取区域" FontWeight="Bold" />
                <Run Text=" | ESC 取消 | 松开鼠标确认" />
            </TextBlock>
        </Border>
    </Grid>
</Window>
