<UserControl x:Class="MacroStudio.Controls.SequencePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroStudio.Controls">
    <Grid x:Name="SequenceRoot"
          ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="NameLabelText" Text="名称" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="MacroNameBox"
                             Height="34"
                             FontSize="15"
                             LostFocus="MacroNameBox_LostFocus"
                             KeyDown="MacroNameBox_KeyDown" />
                    <TextBlock x:Name="MacroNameText"
                               Text="-"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,5,0,0"
                               FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock x:Name="ScheduledStepsLabelText" Text="计划步骤" Style="{StaticResource FieldLabel}" />
                    <TextBlock x:Name="StepCountText" Text="0" FontSize="24" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="14,0,0,0">
                    <TextBlock x:Name="DurationLabelText" Text="时长" Style="{StaticResource FieldLabel}" />
                    <TextBlock x:Name="DurationText" Text="0 ms" FontSize="24" FontWeight="SemiBold" />
                </StackPanel>
                <WrapPanel Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button x:Name="SaveLibraryButton" Style="{StaticResource PrimaryButton}" MinWidth="96" Content="保存到库" Click="SaveLibrary_Click" />
                    <Button x:Name="RunNowHeaderButton" MinWidth="86" Content="立即运行" Click="RunNow_Click" />
                    <Button x:Name="StopHeaderButton" MinWidth="70" Content="停止" Style="{StaticResource DangerButton}" Click="Stop_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="12">
            <local:StepSequencePanel x:Name="StepSequenceControl" />
        </Border>

    </Grid>
</UserControl>
