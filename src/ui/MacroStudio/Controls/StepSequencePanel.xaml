<UserControl x:Class="MacroStudio.Controls.StepSequencePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroStudio.Controls">
    <UserControl.Resources>
        <Style x:Key="StepRowActionButton" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Hover}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Selection}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepRowDeleteActionButton" TargetType="Button" BasedOn="{StaticResource StepRowActionButton}">
            <Setter Property="Foreground" Value="{DynamicResource Danger}" />
        </Style>

        <DataTemplate x:Key="StepTemplate">
            <Border x:Name="StepRow"
                    Style="{StaticResource SoftListItemBorder}"
                    Padding="8,7"
                    Margin="{Binding LeftMargin}"
                    Cursor="Hand"
                    MouseLeftButtonUp="StepRow_MouseLeftButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Icon}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ActionIndicator}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="StepTitleText"
                               Grid.Column="2"
                               Text="{Binding Title}"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               MouseLeftButtonUp="StepTitle_MouseLeftButtonUp" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Badge}"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,4,0" />
                    <StackPanel x:Name="RowActions"
                                Grid.Column="4"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <Button x:Name="StepCopyButton"
                                Style="{StaticResource StepRowActionButton}"
                                Content="⧉"
                                ToolTip="复制"
                                Click="StepCopy_Click" />
                        <Button x:Name="StepRowDeleteButton"
                                Style="{StaticResource StepRowDeleteActionButton}"
                                Content="×"
                                ToolTip="删除"
                                Click="StepRowDelete_Click" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="StepRow" Property="IsMouseOver" Value="True">
                    <Setter TargetName="StepRow" Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsStructural}" Value="True">
                    <Setter TargetName="StepRow" Property="Background" Value="{DynamicResource ControlBackground}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Index}" Value="-1">
                    <Setter TargetName="RowActions" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConditionEndpoint}" Value="True">
                    <Setter TargetName="StepTitleText" Property="Foreground" Value="#FF3B30" />
                    <Setter TargetName="StepTitleText" Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="StepSequenceRoot"
          ClipToBounds="True"
          PreviewMouseDown="SequenceRoot_PreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel x:Name="ToolbarPanel" Margin="4,0,4,10" LastChildFill="True">
            <Border x:Name="SequenceToolbarGroup"
                    DockPanel.Dock="Right"
                    Padding="4"
                    Background="{DynamicResource ControlBackground}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel x:Name="SequenceToolbarButtonStrip" Orientation="Horizontal">
                    <Button x:Name="StepUndoButton"
                            Style="{StaticResource SequenceToolbarIconButton}"
                            Content="&#xE7A7;"
                            ToolTip="{Binding Text, ElementName=StepUndoText}"
                            Click="StepUndo_Click"
                            IsEnabled="False" />
                    <Button x:Name="StepUpButton"
                            Style="{StaticResource SequenceToolbarIconButton}"
                            Content="&#xE74A;"
                            ToolTip="{Binding Text, ElementName=StepUpText}"
                            Click="StepUp_Click" />
                    <Button x:Name="StepDownButton"
                            Style="{StaticResource SequenceToolbarIconButton}"
                            Content="&#xE74B;"
                            ToolTip="{Binding Text, ElementName=StepDownText}"
                            Click="StepDown_Click" />
                    <Button x:Name="StepDeleteButton"
                            Style="{StaticResource SequenceToolbarDangerIconButton}"
                            Content="&#xE74D;"
                            ToolTip="{Binding Text, ElementName=StepDeleteText}"
                            Click="StepDelete_Click" />
                    <Button x:Name="StepClearButton"
                            Style="{StaticResource SequenceToolbarDangerIconButton}"
                            Content="&#xE894;"
                            ToolTip="{Binding Text, ElementName=StepClearText}"
                            Click="StepClear_Click" />
                </StackPanel>
            </Border>
            <Grid>
                <TextBlock x:Name="SequenceTitleText" Text="序列" Style="{StaticResource PanelTitle}" />
                <TextBlock x:Name="StepUndoText" Text="撤回" Visibility="Collapsed" />
                <TextBlock x:Name="StepUpText" Text="上移" Visibility="Collapsed" />
                <TextBlock x:Name="StepDownText" Text="下移" Visibility="Collapsed" />
                <TextBlock x:Name="StepDeleteText" Text="删除" Visibility="Collapsed" />
                <TextBlock x:Name="StepClearText" Text="清空" Visibility="Collapsed" />
            </Grid>
        </DockPanel>

        <Grid Grid.Row="1">
            <ListBox x:Name="StepList"
                     AllowDrop="True"
                     SelectionMode="Extended"
                     ItemTemplate="{StaticResource StepTemplate}"
                     SelectionChanged="StepList_SelectionChanged"
                     PreviewMouseLeftButtonDown="StepList_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="StepList_PreviewMouseMove"
                     PreviewMouseLeftButtonUp="StepList_PreviewMouseLeftButtonUp"
                     LostMouseCapture="StepList_LostMouseCapture"
                     DragOver="StepList_DragOver"
                     DragLeave="StepList_DragLeave"
                     Drop="StepList_Drop"
                     HorizontalContentAlignment="Stretch" />
            <Border x:Name="SelectionRectangle"
                    Panel.ZIndex="20"
                    BorderBrush="{DynamicResource Accent}"
                    BorderThickness="1"
                    Background="{StaticResource SelectionBandBrush}"
                    CornerRadius="6"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
            </Border>
            <Border x:Name="DropIndicator"
                    Tag="{StaticResource DropIndicatorPulseStoryboard}"
                    Panel.ZIndex="30"
                    Height="4"
                    Margin="10,0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource Accent}"
                    CornerRadius="2"
                    Opacity="0.9"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <Border.RenderTransform>
                    <TranslateTransform Y="0" />
                </Border.RenderTransform>
            </Border>
        </Grid>

        <TextBlock x:Name="SelectedStepText"
                   Grid.Row="2"
                   Text="把动作拖到这里，或直接点击右侧添加项。"
                   Foreground="{DynamicResource SecondaryText}"
                   TextWrapping="Wrap"
                   Margin="4,8,4,0" />

        <Popup x:Name="InlineStepEditorPopup"
               Grid.RowSpan="3"
               Placement="Right"
               Closed="InlineStepEditorPopup_Closed"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade">
            <Border MinWidth="300" MaxWidth="340">
                <local:StepEditorPanel x:Name="InlineStepEditor" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
