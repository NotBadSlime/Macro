<Window x:Class="MacroStudio.Controls.ThenActionsEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MacroStudio.Controls"
        Title="编辑触发动作"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBackground}">
    <Window.Resources>
        <DataTemplate x:Key="ThenActionStepTemplate">
            <Border Style="{StaticResource SoftListItemBorder}"
                    Padding="8,7"
                    Margin="{Binding LeftMargin}"
                    Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Icon}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ActionIndicator}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Title}"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Badge}"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,4,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="4,0,4,10">
                    <TextBlock Text="触发后执行" Style="{StaticResource PanelTitle}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="MoveUpButton" MinWidth="52" Content="上移" Click="MoveUp_Click" />
                        <Button x:Name="MoveDownButton" MinWidth="52" Content="下移" Click="MoveDown_Click" />
                        <Button x:Name="DuplicateButton" MinWidth="52" Content="复制" Click="Duplicate_Click" />
                        <Button x:Name="DeleteButton" MinWidth="52" Content="删除" Style="{StaticResource DangerButton}" Click="Delete_Click" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <ListBox x:Name="ThenStepList"
                             SelectionMode="Single"
                             ItemTemplate="{StaticResource ThenActionStepTemplate}"
                             SelectionChanged="ThenStepList_SelectionChanged"
                             HorizontalContentAlignment="Stretch" />
                    <TextBlock x:Name="EmptyThenActionsText"
                               Text="暂无动作，从右侧添加一个动作。"
                               Foreground="{DynamicResource SecondaryText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </Grid>

                <TextBlock Grid.Row="2"
                           x:Name="SelectionHintText"
                           Text="点击动作可以修改属性。"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="12"
                           Margin="4,10,4,0" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="添加动作" Style="{StaticResource PanelTitle}" Margin="0,0,0,10" />
                        <Button x:Name="AddDelayButton" Content="延迟" Tag="Delay" Click="AddAction_Click" />
                        <Button x:Name="AddKeyboardButton" Content="键盘按下/抬起" Tag="Keyboard" Click="AddAction_Click" />
                        <Button x:Name="AddMouseButton" Content="鼠标按下/抬起" Tag="MouseButton" Click="AddAction_Click" />
                        <Button x:Name="AddMoveButton" Content="鼠标移动" Tag="MouseMove" Click="AddAction_Click" />
                        <Button x:Name="AddWheelButton" Content="滚轮" Tag="MouseWheel" Click="AddAction_Click" />
                        <Button x:Name="AddTextButton" Content="文本" Tag="Text" Click="AddAction_Click" />
                        <Button x:Name="AddMacroButton" Content="宏" Tag="Macro" Click="AddAction_Click" />
                        <Button x:Name="AddLoopButton" Content="循环" Tag="Loop" Click="AddAction_Click" />
                    </StackPanel>
                </Border>

                <local:StepEditorPanel x:Name="StepEditorPanel" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="CancelButton"
                    MinWidth="86"
                    Content="取消"
                    Click="Cancel_Click" />
            <Button x:Name="SaveButton"
                    MinWidth="96"
                    Content="保存"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
